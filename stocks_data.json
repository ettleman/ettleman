    .btn-home:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(79, 70, 229, 0.35);
        color: white;
        text-decoration: none;
    }
    .btn-back {
        background: white;
        color: #4F46E5;
        padding: 0.875rem 2rem;
        border-radius: 12px;
        text-decoration: none;
        font-weight: 600;
        border: 2px solid #4F46E5;
        transition: all 0.3s ease;
        display: inline-block;
    }
    .btn-back:hover {
        background: #f8f9fa;
        color: #4F46E5;
        text-decoration: none;
        transform: translateY(-2px);
    }
    @media (max-width: 768px) {
