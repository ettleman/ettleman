                        <option value="">Select category...</option>
                        <option value="bug">🐛 Bug Report</option>
                        <option value="feature">💡 Feature Request</option>
                        <option value="general">💬 General Feedback</option>
                        <option value="other">📝 Other</option>
                    </select>
                </div>
                <div style="margin-bottom: 16px;">
                    <label style="display: block; margin-bottom: 6px; font-weight: 600; color: #2d3748;">Message</label>
                    <textarea name="message" id="feedbackMessage" required rows="5" placeholder="Tell us what's on your mind..." style="width: 100%; padding: 10px; border: 1px solid #cbd5e0; border-radius: 6px; font-size: 0.95rem; resize: vertical;"></textarea>
                </div>
                <div style="margin-bottom: 16px;">
                    <label style="display: block; margin-bottom: 6px; font-weight: 500; color: #718096; font-size: 0.9rem;">
                        <input type="checkbox" id="feedbackIncludeUrl" checked style="margin-right: 6px;">
                        Include current page URL
                    </label>
                </div>
                <div id="feedbackSuccess" style="display: none; background: #c6f6d5; color: #22543d; padding: 12px; border-radius: 6px; margin-bottom: 16px; text-align: center;">
                    ✓ Thank you! Your feedback has been sent.
                </div>
                <div id="feedbackError" style="display: none; background: #fed7d7; color: #742a2a; padding: 12px; border-radius: 6px; margin-bottom: 16px; text-align: center;">
                    ✗ Error sending feedback. Please try again.
                </div>
                <div style="display: flex; gap: 12px;">
                    <button type="submit" id="feedbackSubmitBtn" style="flex: 1; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; border: none; padding: 12px; border-radius: 6px; font-weight: 600; cursor: pointer;">
                        Send Feedback
                    </button>
                    <button type="button" id="feedbackCancelBtn" style="padding: 12px 24px; background: #e2e8f0; color: #2d3748; border: none; border-radius: 6px; font-weight: 600; cursor: pointer;">
                        Cancel
                    </button>
