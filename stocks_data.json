}

.sidebar-content {
    padding: 0;
}

.sidebar-body {
    padding-top: 1rem;
    padding-bottom: 0.75rem;
}

/* Navigation Links */
.sidebar-nav .nav-link {
    color: #4a5568;
    padding: 0.6rem 1rem;
    transition: all 0.2s ease;
    border-left: 3px solid transparent;
    font-size: 0.9rem;
    display: flex;
    align-items: center;
}

.sidebar-nav .nav-link i {
    width: 20px;
    margin-right: 10px;
    font-size: 0.85rem;
    color: #718096;
}

.sidebar-nav .nav-link:hover {
    background-color: #f7fafc;
