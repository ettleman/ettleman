            // Check both desktop and mobile search inputs
            const desktopSearch = document.getElementById('navStockSearch');
            const mobileSearch = document.getElementById('navStockSearchMobile');
            
            let ticker = '';
            if (desktopSearch && desktopSearch.value) {
                ticker = desktopSearch.value.trim().toUpperCase();
            } else if (mobileSearch && mobileSearch.value) {
                ticker = mobileSearch.value.trim().toUpperCase();
            }

            if (ticker) {
                // Every nav search goes to the Investment Advisor deep link
                window.location.href = `/apps/investment-advisor/${ticker}/`;
